{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/devknowsdev/prism-beam/schemas/harvest-entry.schema.json",
  "title": "Prism Beam Harvest Entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "category", "url", "license", "verificationDate", "reuseMode", "copyPolicy"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "license": { "type": "string" },
    "verificationDate": { "type": "string" },
    "reuseMode": {
      "type": "string",
      "enum": ["import-dependency", "wrap-sidecar", "provider-adapter", "reimplement-pattern", "reference-only", "avoid"]
    },
    "copyPolicy": { "type": "string" },
    "harvestTypes": { "type": "array", "items": { "type": "string" } },
    "prismTargets": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "attributionRequired": { "type": "boolean" },
    "implementationNotes": { "type": "string" }
  }
}
